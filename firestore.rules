rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default-deny catch-all safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Authentication indicators
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      // Check either for the bootstrapped admin email or DB profile role
      return isSignedIn() && (
        request.auth.token.email == "playbookstudio76@gmail.com" ||
        request.auth.token.email == "sohansahustudy@gmail.com" ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin")
      );
    }

    // Users Collection
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create, update: if (
        isOwner(userId) && (
          // Forbid users from escalating their own privilege to admin unless they are the official bootstrap email
          request.resource.data.role == "customer" || 
          request.resource.data.email == "playbookstudio76@gmail.com" ||
          request.resource.data.email == "sohansahustudy@gmail.com" ||
          (resource != null && resource.data.role == request.resource.data.role)
        )
      ) || isAdmin();
      allow delete: if isAdmin();
    }

    // Products Collection
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Categories Collection
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Orders Collection
    match /orders/{orderId} {
      // Restrict list/get requests to personal orders or administrators
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // Settings Collection (WhatsApp, Social Links, Global config)
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Banners Collection
    match /banners/{bannerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Coupons Collection
    match /coupons/{couponId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Announcements Collection (Floating Announcement Bars)
    match /announcements/{announcementId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Team Members Collection
    match /team_members/{memberId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Newsletter / Merch Mail Signup Collection
    match /newsletter_emails/{emailId} {
      allow read: if isAdmin();
      allow create, update: if true;
      allow delete: if isAdmin();
    }

    // Wallets Collection
    match /wallets/{walletId} {
      allow read: if isSignedIn() && (request.auth.uid == walletId || isAdmin());
      allow write: if isSignedIn() && (request.auth.uid == walletId || isAdmin());
    }
  }
}
